{
    "name": "sabahweb/swmailerpro-laravel",
    "description": "Laravel mail transport ve API client paketi — SwMailerPro email gateway entegrasyonu",
    "keywords": ["laravel", "mail", "email", "transport", "swmailerpro", "mailchannels"],
    "license": "MIT",
    "authors": [
        {
            "name": "SabahWeb",
            "email": "info@sabahweb.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^12.0",
        "illuminate/http": "^12.0",
        "illuminate/mail": "^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0",
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "SabahWeb\\SwMailerPro\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SabahWeb\\SwMailerPro\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "SabahWeb\\SwMailerPro\\SwMailerProServiceProvider"
            ],
            "aliases": {
                "SwMailerPro": "SabahWeb\\SwMailerPro\\Facades\\SwMailerPro"
            }
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
